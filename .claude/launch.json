{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "kady-web",
      "runtimeExecutable": "bash",
      "runtimeArgs": [
        "-c",
        "cd apps/mobile && npx expo start --web --port 8083"
      ],
      "port": 8083
    },
    {
      "name": "kady-static",
      "runtimeExecutable": "bash",
      "runtimeArgs": [
        "-c",
        "cd apps/mobile && npx serve web-static -s -l 8090"
      ],
      "port": 8090
    },
    {
      "name": "waitlist",
      "runtimeExecutable": "bash",
      "runtimeArgs": [
        "-c",
        "cd apps/waitlist && npm run dev -- --port 5173"
      ],
      "port": 5173
    }
  ]
}