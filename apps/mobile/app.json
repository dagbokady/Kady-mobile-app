{
  "expo": {
    "name": "KADY",
    "slug": "kady",
    "scheme": "kady",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": { "supportsTablet": false, "bundleIdentifier": "ci.kady.app" },
    "android": { "package": "ci.kady.app" },
    "plugins": [
      "expo-router",
      "expo-font",
      ["expo-splash-screen", { "backgroundColor": "#F6F2FB", "resizeMode": "contain" }]
    ],
    "experiments": { "typedRoutes": true }
  }
}
